<!DOCTYPE html>
<html lang="en">
    <head>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>NEXA - Home</title>
        
        <!-- CSS stylesheet -->
        <link rel="stylesheet" href="/dashboard.css">
        <link rel="stylesheet" href="/client/shared/styles/dark-mode.css">

        <!-- Primary Font (Headers & Titles - Manrope) -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">

        <!-- Secondary Font (Body Text - Noto Sans) -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
        
        <!-- Favicon -->
        <link rel="icon" type="image/png" href="/client/shared/assets/Images/nexa-v1.png">
    </head>
    <body>
        <nav class="navbar">
            <div class="nav-brand">
                <div class="nav-brand-main">
                    <img class="nav-logo" src="/client/shared/assets/Images/nexa-v1.png" alt="" aria-hidden="true">
                    <span class="nav-title">NEXA</span>
                </div>

                <button class="menu-toggle" aria-label="Toggle navigation">
                    <img class="app-icon" src="/client/shared/assets/Icons/menu.svg" alt="" aria-hidden="true">
                </button>
            </div>
            
            <ul class="nav-list">
                <li><a href="/" class="nav-item active" aria-label="Home"><img class="app-icon nav-item-icon" src="/client/shared/assets/Icons/home.svg" alt="" aria-hidden="true"> <span class="nav-item-label">Home</span></a></li>
                <li>
                    <details class="nav-group" open>
                        <summary aria-label="Study"><span class="nav-summary-main"><img class="app-icon nav-summary-icon" src="/client/shared/assets/Icons/school.svg" alt="" aria-hidden="true"> <span class="nav-summary-label">Study</span></span><img class="app-icon nav-chevron" src="/client/shared/assets/Icons/next.svg" alt="" aria-hidden="true"></summary>
                        <ul class="nav-submenu">
                            <li><a href="/assignments">Assignments</a></li>
                            <li><a href="/study-planner">Study Planner</a></li>
                            <li><a href="/tasks">Tasks</a></li>
                        </ul>
                    </details>
                </li>
                <li>
                    <details class="nav-group">
                        <summary aria-label="Life"><span class="nav-summary-main"><img class="app-icon nav-summary-icon" src="/client/shared/assets/Icons/habits.svg" alt="" aria-hidden="true"> <span class="nav-summary-label">Life</span></span><img class="app-icon nav-chevron" src="/client/shared/assets/Icons/next.svg" alt="" aria-hidden="true"></summary>
                        <ul class="nav-submenu">
                            <li><a href="/habits">Habits</a></li>
                        </ul>
                    </details>
                </li>
                <li>
                    <details class="nav-group">
                        <summary aria-label="Career"><span class="nav-summary-main"><img class="app-icon nav-summary-icon" src="/client/shared/assets/Icons/career.svg" alt="" aria-hidden="true"> <span class="nav-summary-label">Career</span></span><img class="app-icon nav-chevron" src="/client/shared/assets/Icons/next.svg" alt="" aria-hidden="true"></summary>
                        <ul class="nav-submenu">
                            <li><a href="/job-applications">Job Applications</a></li>
                        </ul>
                    </details>
                </li>
                <li>
                    <details class="nav-group">
                        <summary aria-label="Financial"><span class="nav-summary-main"><img class="app-icon nav-summary-icon" src="/client/shared/assets/Icons/financial.svg" alt="" aria-hidden="true"> <span class="nav-summary-label">Financial</span></span><img class="app-icon nav-chevron" src="/client/shared/assets/Icons/next.svg" alt="" aria-hidden="true"></summary>
                        <ul class="nav-submenu">
                            <li><a href="/finances">Finances</a></li>
                        </ul>
                    </details>
                </li>
            </ul>
        </nav>

        <main class="content">
            <div class="home-overview">
                <div class="home-date-summary">
                    <button id="today-btn">TODAY</button>
                    
                    <div class="date-header">
                        <div class="date-row">
                            <button id="previous-btn" aria-label="Previous day"><img class="app-icon" src="/client/shared/assets/Icons/prev(circle).svg" alt="" aria-hidden="true"></button>

                            <div class="date-text">
                                <h1 id="date-display"></h1>
                                <h2 id="day-display"></h2>
                            </div>

                            <button id="next-btn" aria-label="Next day"><img class="app-icon" src="/client/shared/assets/Icons/next(circle).svg" alt="" aria-hidden="true"></button>
                        </div>
                    </div>
                </div>

                <aside class="upcoming-assignments-widget">
                    <div class="upcoming-assignments-header">
                        <h3>UPCOMING ASSIGNMENTS</h3>
                    </div>
                    <ul id="upcoming-assignments-list"></ul>
                </aside>
            </div>
            
            <hr>
            <h2>Welcome, <span id="welcome-name"></span>.</h2> <!-- just a placeholder for now, will use a variable that stores the logged in user later to replace this -->

            <!-- Today's Tasks & Assignments Due dashboard cards -->
            <div class="dashboard-cards">
                    <div class="today-tasks">
                    <div class="today-tasks-header">
                        <h2>TODAY'S TASKS</h2>

                        <div class="today-tasks-controls">
                            <button class="btn-primary" id="add-task-btn"><img class="app-icon" src="/client/shared/assets/Icons/add-circle.svg" alt="" aria-hidden="true"></button>

                            <div class="controls-group">
                                <label class="control-label" for="sort-select">Sort</label>
                                <select class="control-select" id="sort-select">
                                    <option value="az">A-Z</option>
                                    <option value="za">Z-A</option>
                                    <option value="priority">Priority</option>
                                    <option value="lastUpdated">Last Updated</option>
                                    <option value="createdNewOld">Created (new -> old)</option>
                                    <option value="createdOldNew">Created (old -> new)</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Task list rendered here via JS -->
                    <ul id="task-list"></ul>
                </div>

                <div class="assignments-due">
                    <div class="assignments-due-header">
                        <h2>ASSIGNMENTS DUE TODAY</h2>
                    </div>
                    <ul id="assignments-due-list"></ul>
                    <div id="assignments-due-more" class="assignments-due-more hidden"></div>
                </div>

                <div class="calendar-widget">
                    <div class="calendar-widget-header">
                        <h2 id="calendar-month-label">MONTH YEAR</h2>
                        <div class="calendar-widget-nav">
                            <button type="button" class="calendar-nav" id="calendar-prev-month" aria-label="Previous month"><img class="app-icon" src="/client/shared/assets/Icons/prev(circle).svg" alt="" aria-hidden="true"></button>
                            <button type="button" class="calendar-nav" id="calendar-next-month" aria-label="Next month"><img class="app-icon" src="/client/shared/assets/Icons/next(circle).svg" alt="" aria-hidden="true"></button>
                        </div>
                    </div>
                    <div class="calendar-weekdays" aria-hidden="true">
                        <span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span><span>S</span>
                    </div>
                    <div id="calendar-days" class="calendar-days" role="grid" aria-label="Calendar"></div>
                </div>
            </div>

            <template id="assignment-due-item-template">
                <li class="assignment-due-item">
                    <div class="assignment-due-task"></div>
                    <div class="assignment-due-subject"></div>
                    <div class="assignment-due-meta">
                        <span class="assignment-due-date-label"></span>
                        <span class="assignment-priority-group">
                            <span class="assignment-priority-dot" aria-hidden="true"></span>
                            <span class="assignment-priority-label"></span>
                        </span>
                        <span class="assignment-status-label"></span>
                    </div>
                </li>
            </template>

            <template id="assignment-due-empty-template">
                <li class="assignment-due-empty">No assignments due on this date.</li>
            </template>

            <template id="upcoming-assignment-item-template">
                <li class="upcoming-assignment-item">
                    <a class="upcoming-assignment-link" href="#">
                        <div class="upcoming-assignment-countdown">
                            <div class="upcoming-assignment-badge" aria-hidden="true">
                                <img class="app-icon" src="/client/shared/assets/Icons/exclamation.svg" alt="">
                                <span>Urgent</span>
                            </div>
                            <span class="upcoming-assignment-days-value"></span>
                            <span class="upcoming-assignment-days-label"></span>
                        </div>

                        <div class="upcoming-assignment-content">
                            <div class="upcoming-assignment-task"></div>
                            <div class="upcoming-assignment-subject"></div>
                            <div class="upcoming-assignment-due-date"></div>
                        </div>
                    </a>
                </li>
            </template>

            <template id="upcoming-assignment-empty-template">
                <li class="upcoming-assignment-empty">No upcoming assignments yet.</li>
            </template>

            <template id="task-empty-template">
                <li class="task-empty">No tasks to show yet.</li>
            </template>

             <div id="modal-backdrop" class="hidden"></div>

             <!-- ADD TASK MODAL -->
             <div id="add-task-modal" class="hidden" role="dialog" aria-modal="true">
                <img class="modal-brand-logo" src="/client/shared/assets/Images/nexa-v1.png" alt="" aria-hidden="true">
                <h3 id="task-modal-title" align="center">ADD TASK</h3>
                <!-- Title -->
                 <div class="form-row">
                    <label for="task-title"><strong>Title</strong></label>
                    <input id="task-title" type="text" placeholder="e.g., Finish tutorial">
                 </div>

                <!-- Notes -->
                <div class="form-row">
                    <label for="task-notes"><strong>Notes</strong></label>
                    <textarea id="task-notes" rows="3" placeholder="Optional..."></textarea>
                </div>

                <!-- Priority -->
                <div class="form-row">
                    <label for="task-priority"><strong>Priority</strong></label>
                    <select id="task-priority">
                        <option value="high">High</option>
                        <option value="medium" selected>Medium</option>
                        <option value="low">Low</option>
                    </select>
                </div> 

                <div class="form-row">
                    <label for="task-workflow-status"><strong>Status</strong></label>
                    <select id="task-workflow-status">
                        <option value="not-started" selected>Not started</option>
                        <option value="in-progress">In progress</option>
                        <option value="completed">Completed</option>
                    </select>
                </div>
                
                 <!-- success message (if added task successfully) -->
                  <p id="task-status" class="task-status"></p>

                 <div class="modal-actions">
                    <button class="btn-secondary" id="cancel-task-btn"><span class="ui-btn-label">Cancel</span><img class="app-icon" src="/client/shared/assets/Icons/cancel.svg" alt="" aria-hidden="true"></button>
                    <button class="btn-secondary hidden" id="delete-task-btn"><span class="ui-btn-label">Delete</span><img class="app-icon" src="/client/shared/assets/Icons/delete.svg" alt="" aria-hidden="true"></button>
                    <button class="btn-secondary" id="confirm-task-btn"><span class="ui-btn-label">Add</span><img class="app-icon" src="/client/shared/assets/Icons/check.svg" alt="" aria-hidden="true"></button> <!-- task adding confirmation -->
                 </div>
             </div>
            <%- include("../partials/system-settings") %>
        </main>
        
        <script src="/client/shared/theme-boot.js"></script>
        <script src="/client/app-storage.js"></script>
        <script src="/client/shared/settings-modal.js"></script>
        <script src="/index.js"></script>
    </body>
</html>
