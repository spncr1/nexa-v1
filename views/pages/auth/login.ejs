<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXA - Login</title>

    <!-- CSS stylesheet -->
    <link rel="stylesheet" href="/client/shared/styles/auth.css">
    
    <!-- Primary Font (Headers & Titles - Manrope) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">

    <!-- Secondary Font (Body Text - Noto Sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
        
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/client/shared/assets/Images/nexa-v1.png">
</head>
<body>

    <main class="content">
        <% const formValues = typeof values !== 'undefined' ? values : {}; %>
        <% const fieldErrors = typeof errors !== 'undefined' ? errors : {}; %>
        <% const alertError = typeof formError !== 'undefined' ? formError : null; %>
        <% const alertSuccess = typeof successMessage !== 'undefined' ? successMessage : null; %>

        <img id="nexa-logo" src="/client/shared/assets/Images/nexa-v1.png">
        <h1>NEXA Login</h1>

        <% if (alertSuccess) { %>
            <p class="auth-status success"><%= alertSuccess %></p>
        <% } %>

        <% if (alertError) { %>
            <p class="auth-status error"><%= alertError %></p>
        <% } %>

        <form class="auth-form" action="/login" method="POST" novalidate>
            <div class="form-row <%= fieldErrors.email ? 'has-error' : '' %>">
                <label for="email">Email</label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    value="<%= formValues.email || '' %>"
                    autocomplete="email"
                    required
                    aria-invalid="<%= fieldErrors.email ? 'true' : 'false' %>"
                    <%= fieldErrors.email ? 'aria-describedby="email-error"' : '' %>
                >
                <% if (fieldErrors.email) { %>
                    <p class="field-error" id="email-error"><%= fieldErrors.email %></p>
                <% } %>
            </div>

            <div class="form-row <%= fieldErrors.password ? 'has-error' : '' %>">
                <label for="password">Password</label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    autocomplete="current-password"
                    maxlength="64"
                    required
                    aria-invalid="<%= fieldErrors.password ? 'true' : 'false' %>"
                    <%= fieldErrors.password ? 'aria-describedby="password-error"' : '' %>
                >
                <% if (fieldErrors.password) { %>
                    <p class="field-error" id="password-error"><%= fieldErrors.password %></p>
                <% } %>
            </div>

            <button type="submit">Login</button>
        </form>

        <div class="auth-footer">
            <a class="auth-link secondary" href="/forgot-password">Forgot password?</a>

            <p>Don't have an account yet?</p> <!-- this is kinda just sitting here for now, but it does the job so i may just come back and polish this later -->

            <a class="auth-link" href="/register">Register</a>
        </div>
    </main>

</body>
</html>
