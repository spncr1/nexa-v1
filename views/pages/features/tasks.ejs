<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>NEXA - Tasks</title>
        
        <!-- CSS stylesheet -->
        <link rel="stylesheet" href="/client/features/Tasks/tasks.css">
        <link rel="stylesheet" href="/client/shared/styles/dark-mode.css">

        <!-- Primary Font (Headers & Titles - Manrope) -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">

        <!-- Secondary Font (Body Text - Noto Sans) -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
        
        <!-- Favicon -->
        <link rel="icon" type="image/png" href="/client/shared/assets/Images/nexa-v1.png">
    </head>
    <body class="tasks-page">

        <nav class="navbar">
            <div class="nav-brand">
                <div class="nav-brand-main">
                    <img class="nav-logo" src="/client/shared/assets/Images/nexa-v1.png" alt="" aria-hidden="true">
                    <span class="nav-title">NEXA</span>
                </div>

                <button class="menu-toggle" aria-label="Toggle navigation">
                    <img class="app-icon" src="/client/shared/assets/Icons/menu.svg" alt="" aria-hidden="true">
                </button>
            </div>
            
            <ul class="nav-list">
                <li><a href="/" class="nav-item" aria-label="Home"><img class="app-icon nav-item-icon" src="/client/shared/assets/Icons/home.svg" alt="" aria-hidden="true"> <span class="nav-item-label">Home</span></a></li>
                <li>
                    <details class="nav-group" open>
                        <summary class="active" aria-label="Study"><span class="nav-summary-main"><img class="app-icon nav-summary-icon" src="/client/shared/assets/Icons/school.svg" alt="" aria-hidden="true"> <span class="nav-summary-label">Study</span></span><img class="app-icon nav-chevron" src="/client/shared/assets/Icons/next.svg" alt="" aria-hidden="true"></summary>
                        <ul class="nav-submenu">
                            <li><a href="/assignments">Assignments</a></li>
                            <li><a href="/study-planner">Study Planner</a></li>
                            <li><a href="/tasks" class="active">Tasks</a></li>
                        </ul>
                    </details>
                </li>
                <li>
                    <details class="nav-group">
                        <summary aria-label="Life"><span class="nav-summary-main"><img class="app-icon nav-summary-icon" src="/client/shared/assets/Icons/habits.svg" alt="" aria-hidden="true"> <span class="nav-summary-label">Life</span></span><img class="app-icon nav-chevron" src="/client/shared/assets/Icons/next.svg" alt="" aria-hidden="true"></summary>
                        <ul class="nav-submenu">
                            <li><a href="/habits">Habits</a></li>
                        </ul>
                    </details>
                </li>
                <li>
                    <details class="nav-group">
                        <summary aria-label="Career"><span class="nav-summary-main"><img class="app-icon nav-summary-icon" src="/client/shared/assets/Icons/career.svg" alt="" aria-hidden="true"> <span class="nav-summary-label">Career</span></span><img class="app-icon nav-chevron" src="/client/shared/assets/Icons/next.svg" alt="" aria-hidden="true"></summary>
                        <ul class="nav-submenu">
                            <li><a href="/job-applications">Job Applications</a></li>
                        </ul>
                    </details>
                </li>
                <li>
                    <details class="nav-group">
                        <summary aria-label="Financial"><span class="nav-summary-main"><img class="app-icon nav-summary-icon" src="/client/shared/assets/Icons/financial.svg" alt="" aria-hidden="true"> <span class="nav-summary-label">Financial</span></span><img class="app-icon nav-chevron" src="/client/shared/assets/Icons/next.svg" alt="" aria-hidden="true"></summary>
                        <ul class="nav-submenu">
                            <li><a href="/finances">Finances</a></li>
                        </ul>
                    </details>
                </li>
            </ul>
        </nav>

        <main class="content">
            <header class="tasks-page-header">
                <h1 class="page-title">TASKS PLANNER</h1>
            </header>

            <section class="tasks-controls" aria-label="Tasks controls">
                <div class="tasks-nav-group">
                    <button id="today-btn">TODAY</button>
                    <button id="previous-btn" class="tasks-nav-btn" aria-label="Previous period"><img class="app-icon" src="/client/shared/assets/Icons/prev(circle).svg" alt="" aria-hidden="true"></button>
                    <button id="next-btn" class="tasks-nav-btn" aria-label="Next period"><img class="app-icon" src="/client/shared/assets/Icons/next(circle).svg" alt="" aria-hidden="true"></button>
                </div>

                <div class="tasks-range-label-wrap">
                    <h2 id="tasks-range-label">Week of ...</h2>
                </div>

                <div class="tasks-view-toggle" role="tablist" aria-label="Calendar view">
                    <button id="week-view-btn" class="btn-secondary active" type="button" role="tab" aria-selected="true">Week</button>
                    <button id="month-view-btn" class="btn-secondary" type="button" role="tab" aria-selected="false">Month</button>
                </div>
            </section>

            <section id="tasks-week-view" class="tasks-surface" aria-label="Weekly tasks schedule">
                <div class="tasks-grid-shell">
                    <div class="tasks-week-header-row">
                        <div class="tasks-time-header">TIME</div>
                        <div id="tasks-week-header" class="tasks-week-header"></div>
                    </div>

                    <div class="tasks-week-body-row">
                        <div id="tasks-week-time-rail" class="tasks-time-rail" aria-hidden="true"></div>
                        <div id="tasks-week-body" class="tasks-week-body"></div>
                    </div>
                </div>
            </section>

            <template id="week-slot-template">
                <div class="week-slot">
                    <button type="button" class="slot-add-btn" aria-label="Add task"><img class="app-icon" src="/client/shared/assets/Icons/add-circle.svg" alt="" aria-hidden="true"></button>
                    <div class="slot-quarter-grid">
                        <div class="slot-quarter" data-quarter="0"></div>
                        <div class="slot-quarter" data-quarter="1"></div>
                        <div class="slot-quarter" data-quarter="2"></div>
                        <div class="slot-quarter" data-quarter="3"></div>
                    </div>
                </div>
            </template>

            <section id="tasks-month-view" class="tasks-surface hidden" aria-label="Monthly tasks schedule">
                <div class="tasks-month-layout">
                    <div class="tasks-month-calendar">
                        <div class="tasks-month-weekdays" aria-hidden="true">
                            <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                        </div>
                        <div id="tasks-month-days" class="tasks-month-days" role="grid" aria-label="Month"></div>
                    </div>

                    <div class="tasks-month-agenda">
                        <h3 id="tasks-selected-date-label" class="tasks-selected-date-label">Selected date</h3>
                        <div class="tasks-month-agenda-grid">
                            <div id="tasks-month-time-rail" class="tasks-time-rail" aria-hidden="true"></div>
                            <div id="tasks-month-body" class="tasks-month-body"></div>
                        </div>
                    </div>
                </div>
            </section>

            <div id="modal-backdrop" class="hidden"></div>

            <div id="add-task-modal" class="hidden" role="dialog" aria-modal="true" aria-label="Add task">
                <img class="modal-brand-logo" src="/client/shared/assets/Images/nexa-v1.png" alt="" aria-hidden="true">
                <h3 id="task-modal-title" align="center">ADD TASK</h3>

                <div class="form-row">
                    <label for="task-title"><strong>Title</strong></label>
                    <input id="task-title" type="text" placeholder="e.g., Finish tutorial">
                </div>

                <div class="form-row">
                    <label for="task-notes"><strong>Notes</strong></label>
                    <textarea id="task-notes" rows="3" placeholder="Optional..."></textarea>
                </div>

                <div class="form-row">
                    <label for="task-priority"><strong>Priority</strong></label>
                    <select id="task-priority">
                        <option value="high">High</option>
                        <option value="medium" selected>Medium</option>
                        <option value="low">Low</option>
                    </select>
                </div>

                <div class="form-row">
                    <label for="task-workflow-status"><strong>Status</strong></label>
                    <select id="task-workflow-status">
                        <option value="not-started" selected>Not started</option>
                        <option value="in-progress">In progress</option>
                        <option value="completed">Completed</option>
                    </select>
                </div>

                <div class="form-row">
                    <label for="task-time"><strong>Time</strong></label>
                    <input id="task-time" type="time" step="60">
                </div>

                <p id="task-status" class="task-status"></p>
                <p id="task-schedule-context" class="task-schedule-context"></p>

                <div class="modal-actions">
                    <button class="btn-secondary" id="cancel-task-btn"><span class="ui-btn-label">Cancel</span><img class="app-icon" src="/client/shared/assets/Icons/cancel.svg" alt="" aria-hidden="true"></button>
                    <button class="btn-secondary hidden" id="delete-task-btn"><span class="ui-btn-label">Delete</span><img class="app-icon" src="/client/shared/assets/Icons/delete.svg" alt="" aria-hidden="true"></button>
                    <button class="btn-secondary" id="confirm-task-btn"><span class="ui-btn-label">Add</span><img class="app-icon" src="/client/shared/assets/Icons/check.svg" alt="" aria-hidden="true"></button>
                </div>
            </div>
            <%- include("../../partials/system-settings") %>
        </main>
        
        <script src="/client/shared/theme-boot.js"></script>
        <script src="/client/app-storage.js"></script>
        <script src="/client/shared/settings-modal.js"></script>
        <script src="/client/features/Tasks/tasks.js"></script>
    </body>
</html>
