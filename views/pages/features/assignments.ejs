<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>NEXA - Assignments</title>
        
        <!-- CSS stylesheet -->
        <link rel="stylesheet" href="/client/features/Assignments/assignments.css">
        <link rel="stylesheet" href="/client/shared/styles/dark-mode.css">

        <!-- Primary Font (Headers & Titles - Manrope) -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">

        <!-- Secondary Font (Body Text - Noto Sans) -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
        
        <!-- Favicon -->
        <link rel="icon" type="image/png" href="/client/shared/assets/Images/nexa-v1.png">
    </head>
    <body>

        <nav class="navbar">
            <div class="nav-brand">
                <div class="nav-brand-main">
                    <img class="nav-logo" src="/client/shared/assets/Images/nexa-v1.png" alt="" aria-hidden="true">
                    <span class="nav-title">NEXA</span>
                </div>

                <button class="menu-toggle" aria-label="Toggle navigation">
                    <img class="app-icon" src="/client/shared/assets/Icons/menu.svg" alt="" aria-hidden="true">
                </button>
            </div>
            
            <ul class="nav-list">
                <li><a href="/" class="nav-item" aria-label="Home"><img class="app-icon nav-item-icon" src="/client/shared/assets/Icons/home.svg" alt="" aria-hidden="true"> <span class="nav-item-label">Home</span></a></li>
                <li>
                    <details class="nav-group" open>
                        <summary class="active" aria-label="Study"><span class="nav-summary-main"><img class="app-icon nav-summary-icon" src="/client/shared/assets/Icons/school.svg" alt="" aria-hidden="true"> <span class="nav-summary-label">Study</span></span><img class="app-icon nav-chevron" src="/client/shared/assets/Icons/next.svg" alt="" aria-hidden="true"></summary>
                        <ul class="nav-submenu">
                            <li><a href="/assignments" class="active">Assignments</a></li>
                            <li><a href="/study-planner">Study Planner</a></li>
                            <li><a href="/tasks">Tasks</a></li>
                        </ul>
                    </details>
                </li>
                <li>
                    <details class="nav-group">
                        <summary aria-label="Life"><span class="nav-summary-main"><img class="app-icon nav-summary-icon" src="/client/shared/assets/Icons/habits.svg" alt="" aria-hidden="true"> <span class="nav-summary-label">Life</span></span><img class="app-icon nav-chevron" src="/client/shared/assets/Icons/next.svg" alt="" aria-hidden="true"></summary>
                        <ul class="nav-submenu">
                            <li><a href="/habits">Habits</a></li>
                        </ul>
                    </details>
                </li>
                <li>
                    <details class="nav-group">
                        <summary aria-label="Career"><span class="nav-summary-main"><img class="app-icon nav-summary-icon" src="/client/shared/assets/Icons/career.svg" alt="" aria-hidden="true"> <span class="nav-summary-label">Career</span></span><img class="app-icon nav-chevron" src="/client/shared/assets/Icons/next.svg" alt="" aria-hidden="true"></summary>
                        <ul class="nav-submenu">
                            <li><a href="/job-applications">Job Applications</a></li>
                        </ul>
                    </details>
                </li>
                <li>
                    <details class="nav-group">
                        <summary aria-label="Financial"><span class="nav-summary-main"><img class="app-icon nav-summary-icon" src="/client/shared/assets/Icons/financial.svg" alt="" aria-hidden="true"> <span class="nav-summary-label">Financial</span></span><img class="app-icon nav-chevron" src="/client/shared/assets/Icons/next.svg" alt="" aria-hidden="true"></summary>
                        <ul class="nav-submenu">
                            <li><a href="/finances">Finances</a></li>
                        </ul>
                    </details>
                </li>
            </ul>
        </nav>

        <main class="content">
            <header class="assignment-page-header">
                <h1 class="page-title">ASSIGNMENTS SCHEDULE <span class="page-subtitle semester-label"></span></h1>
            </header>

            <!-- MAIN LAYOUT -->
            <section class="assignments-layout">
                <!-- LEFT COLUMN -->
                <aside class="subjects-panel" aria-label="Subjects">
                    <div class="subjects-panel-header">
                        <h3 class="panel-title">Subjects <span class="panel-subtitle semester-label"></span></h3>

                        <button type="button" class="btn-primary" id="add-subject-btn" aria-label="Add Subject"><img class="app-icon" src="/client/shared/assets/Icons/add-circle.svg" alt="" aria-hidden="true"></button>
                    </div>

                    <!-- Subjects list rendered here via JS -->
                    <ul id="subjects-list"></ul>
                </aside>

                <!-- MIDDLE COLUMN -->
                <section class="assignments-main" aria-label="Assessment weightings">
                    <div class="weighting-carousel" id="weighting-carousel">
                        <div class="carousel-header">
                            <h3>Assessment Weightings</h3>
                        </div>

                        <div class="carousel-content">
                            <div class="carousel-slide" id="carousel-slide">
                                <!-- content here -->
                            </div>
                            <div class="carousel-footer">
                                <button class="carousel-nav" id="carousel-prev" aria-label="Previous subject"><img class="app-icon" src="/client/shared/assets/Icons/prev(circle).svg" alt="" aria-hidden="true"></button>
                                <div class="carousel-subject" id="carousel-subject"></div>
                                <button class="carousel-nav" id="carousel-next" aria-label="Next subject"><img class="app-icon" src="/client/shared/assets/Icons/next(circle).svg" alt="" aria-hidden="true"></button>
                            </div>
                        </div>

                        <div class="carousel-dots" id="carousel-dots"></div>
                    </div>
                    <!-- any future centred content will go here-->
                </section>

                <!-- CONTROLS COLUMN -->
                <aside class="assignments-controls" aria-label="Assignments controls">
                    <div class="controls-group">
                        <label class="control-label" for="add-assignment-btn">Add Assignments</label>
                        <button type="button" class="btn-primary" id="add-assignment-btn"><img class="app-icon" src="/client/shared/assets/Icons/add-circle.svg" alt="" aria-hidden="true"></button>
                    </div>

                    <div class="controls-group">
                        <label class="control-label" for="assignments-sort">Sort</label>
                        <select id="assignments-sort" class="control-select">
                            <option value="dueSoon">Due date (soonest)</option>
                            <option value="dueLate">Due date (latest)</option>
                            <option value="weightHigh">Weighting (high -> low)</option>
                            <option value="weightLow">Weighting (low -> high) </option>
                            <option value="priority">Priority</option>
                        </select>
                    </div>

                    <div class="controls-group">
                        <label class="control-label" for="assignments-filter">Filter (by priority)</label>
                        <select id="assignments-filter" class="control-select">
                            <option value="all">All</option>
                            <option value="low">Low</option>
                            <option value="medium">Medium</option>
                            <option value="high">High</option>
                        </select>
                    </div>
                </aside>

                <!-- RIGHT COLUMN: VISUAL WIDGETS -->
                 <aside class="assignments-widgets" aria-label="Summary widgets">
                    <div class="widget-card">
                        <div class="widget-title">Total Course Assignments</div>
                        <div class="total-assignments-widget">
                            <div id="total-assignments-bars" class="bars"></div>

                            <div class="axis">
                                <div class="axis-bottom-line"></div>
                                <div class="axis-vertical-line">
                                    <span>0</span>
                                    <span>1</span>
                                    <span>2</span>
                                    <span>3</span>
                                    <span>4</span>
                                    <span>5</span>
                                    <span id="total-assignments-max">6</span>
                                </div>
                            </div>

                            <div id="total-assignments-legend" class="legend"></div>
                        </div>
                    </div>
                    
                    <div class="widget-card">
                        <div class="widget-title">Assignments Dashboard</div>

                        <div class="dash-widget">
                            <div class="dash-tabs">
                                <button type="button" class="dash-nav" id="dash-prev" aria-label="Previous dashboard"><img class="app-icon" src="/client/shared/assets/Icons/prev(circle).svg" alt="" aria-hidden="true"></button>
                                <div class="dash-label" id="dash-label">Status</div>
                                <button type="button" class="dash-nav" id="dash-next" aria-label="Next dashboard"><img class="app-icon" src="/client/shared/assets/Icons/next(circle).svg" alt="" aria-hidden="true"></button>
                            </div>

                            <div class="dash-slide" id="dash-slide">
                                <!-- JS injects slide content here -->
                            </div>

                            <div class="dash-dots" id="dash-dots"></div>
                        </div>
                    </div>
                 </aside>

                 <div class="assignments-table-card" aria-label="All Assignments table">
                    <div class="assignments-table-header">
                        <h2 class="table-title">All Assignments <span class="page-subtitle semester-label"></span></h2>
                        <button class="btn-secondary" id="reset-btn"><span class="ui-btn-label">Reset</span><img class="app-icon" src="/client/shared/assets/Icons/delete.svg" alt="" aria-hidden="true"></button> <!-- would "clear all assignments" be more suitable here? -->
                    </div>

                    <div class="assignments-table-wrap">
                            <table class="assignments-table">
                                <thead>
                                    <tr>
                                        <th>Course</th>
                                        <th>Task</th>
                                        <th>Priority</th>
                                        <th>Status</th>
                                        <th>Due Date</th>
                                        <th>Weighting (%)</th>
                                        <th>Share of Subject</th>
                                    </tr>
                                </thead>

                                <tbody id="assignments-body">
                                </tbody>
                            </table>
                        </div>
                </div>
            </section>

             <div id="modal-backdrop" class="hidden"></div>

             <!-- SUBJECT MODAL BACKDROP -->
              <div id="subject-modal-backdrop" class="hidden"></div>

              <!-- ADD SUBJECT MODAL -->
               <div id="add-subject-modal" class="hidden" role="dialog" aria-modal="true" aria-label="Add Subject">
                <h3 id="subject-modal-title" align="center">ADD SUBJECT</h3>

                <div class="form-row">
                    <label for="subject-name"><strong>Subject name</strong></label>
                    <input id="subject-name" type="text" placeholder="e.g., Data Structures & Algorithms">
                </div>

                <p id="subject-status" class="task-status"></p>

                <div class="modal-actions">
                    <button class="btn-secondary" id="cancel-subject-btn"><span class="ui-btn-label">Cancel</span><img class="app-icon" src="/client/shared/assets/Icons/cancel.svg" alt="" aria-hidden="true"></button>
                    <button class="btn-secondary hidden" id="delete-subject-btn"><span class="ui-btn-label">Delete</span><img class="app-icon" src="/client/shared/assets/Icons/delete.svg" alt="" aria-hidden="true"></button>
                    <button class="btn-secondary" id="confirm-subject-btn"><span class="ui-btn-label">Add</span><img class="app-icon" src="/client/shared/assets/Icons/check.svg" alt="" aria-hidden="true"></button>
                </div>
               </div>
               <!-- ADD/EDIT ASSIGNMENT MODAL -->
               <div id="add-assignment-modal" class="hidden" role="dialog" aria-modal="true" aria-label="Add Assignment">
                <h3 id="assignment-modal-title" align="center">ADD ASSIGNMENT</h3>

                <!-- Course -->
                 <div class="form-row">
                    <label for="assignment-course"><strong>Course</strong></label>
                    <select id="assignment-course"></select>
                 </div>

                 <!-- Task -->
                 <div class="form-row">
                    <label for="assignment-task"><strong>Task</strong></label>
                    <input id="assignment-task" type="text" placeholder="e.g., AT3 Research Report"></input>
                 </div>

                 <!-- Description (not shown on table intentionally) -->
                 <div class="form-row">
                    <label for="assignment-desc"><strong>Description</strong></label>
                    <textarea id="assignment-desc" rows="4" placeholder="Brief summary (max. 500 words)..."></textarea>
                 </div>

                 <!-- Priority -->
                 <div class="form-row">
                    <label for="assignment-priority"><strong>Priority</strong></label>
                    <select id="assignment-priority">
                        <option value="low">Low</option>
                        <option value="medium" selected>Medium</option>
                        <option value="high">High</option>
                    </select>
                 </div>

                 <!-- Status -->
                 <div class="form-row">
                    <label for="assignment-status"><strong>Status</strong></label>
                    <select id="assignment-status">
                        <option value="not-started" selected>Not started</option>
                        <option value="in-progress">In progress</option>
                        <option value="completed">Completed</option>
                    </select>
                 </div>

                 <!-- Due Date -->
                 <div class="form-row">
                    <label for="assignment-due"><strong>Due date</strong></label>
                    <input id="assignment-due" type="date"></input>
                 </div>

                 <!-- Weighting -->
                 <div class="form-row">
                    <label for="assignment-weight"><strong>Weighting (%)</strong></label>
                    <input id="assignment-weight" type="number" min="0" max="100" step="0.1" placeholder="e.g., 20"></input>
                 </div>

                 <p id="assignment-status-text" class="task-status"></p>

                 <div class="modal-actions">
                    <button class="btn-secondary" id="cancel-assignment-btn"><span class="ui-btn-label">Cancel</span><img class="app-icon" src="/client/shared/assets/Icons/cancel.svg" alt="" aria-hidden="true"></button>
                    <button class="btn-secondary" id="delete-assignment-btn"><span class="ui-btn-label">Delete</span><img class="app-icon" src="/client/shared/assets/Icons/delete.svg" alt="" aria-hidden="true"></button>
                    <button class="btn-secondary" id="confirm-assignment-btn"><span class="ui-btn-label">Add</span><img class="app-icon" src="/client/shared/assets/Icons/check.svg" alt="" aria-hidden="true"></button>
                 </div>
               </div>

               <!-- VIEW ASSIGNMENT MODAL (read-only) -->
               <div id="view-assignment-modal" class="hidden" role="dialog" aria-modal="true" aria-label="View Assignment">
                <h3 id="view-assignment-title" align="center">ASSIGNMENT</h3>
                <p id="view-assignment-desc" class="view-assignment-desc"></p>
               </div>

               <%- include("../../partials/system-settings") %>
        </main>
        
        <script src="/client/shared/theme-boot.js"></script>
        <script src="/client/app-storage.js"></script>
        <script src="/client/shared/settings-modal.js"></script>
        <script src="/client/features/Assignments/assignments.js"></script>
    </body>
</html>
