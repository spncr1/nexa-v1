<div id="settings-backdrop" class="hidden" aria-hidden="true"></div>

<div id="system-settings-modal" class="hidden" role="dialog" aria-modal="true" aria-label="System Settings">
    <div class="settings-layout">
        <aside class="settings-sidebar">
            <ul class="settings-sidebar-list">
                <li><button type="button" class="settings-nav" data-tab="general">General</button></li>
                <li><button type="button" class="settings-nav" data-tab="account">Account</button></li>
                <li><button type="button" class="settings-nav" data-tab="customise">Customise</button></li>
            </ul>
        </aside>

        <div class="settings-content">
            <div class="settings-header">
                <h3 class="settings-title">SYSTEM SETTINGS</h3>
                <div id="settings-subtitle" class="settings-subtitle">General</div>
            </div>

            <div class="settings-body">
                <div class="settings-panel" data-panel="general">
                    <div class="setting-row">
                        <div>
                            <div class="setting-labels">Reset App Data?</div>
                        </div>
                        <button type="button" id="reset-app-data-btn" class="setting-action-btn danger"><span class="ui-btn-label">Reset</span><img class="app-icon" src="/client/shared/assets/Icons/delete.svg" alt="" aria-hidden="true"></button>
                    </div>

                    <div class="setting-row">
                        <div>
                            <div class="setting-labels">Load Demo Data?</div>
                        </div>
                        <button type="button" id="load-demo-data-btn" class="setting-action-btn success"><span class="ui-btn-label">Load</span><img class="app-icon" src="/client/shared/assets/Icons/add-circle.svg" alt="" aria-hidden="true"></button>
                    </div>
                </div>

                <div class="settings-panel hidden" data-panel="account">
                    <div class="setting-row">
                        <div>
                            <div class="setting-labels">Name</div>
                        </div>
                        <input type="text" id="account-name-input" class="setting-account-input">
                    </div>

                    <div class="setting-row">
                        <div>
                            <div class="setting-labels">Email</div>
                        </div>
                        <input type="text" id="account-email-input" class="setting-account-input">
                    </div>

                    <div class="setting-row">
                        <div>
                            <div class="setting-labels">Semester label</div>
                        </div>
                        <input type="text" id="account-semester-input" class="setting-account-input">
                    </div>

                    <div class="setting-row">
                        <div>
                            <div class="setting-labels">Save account details</div>
                        </div>
                        <button type="button" id="save-account-btn" class="setting-action-btn success"><span class="ui-btn-label">Save</span><img class="app-icon" src="/client/shared/assets/Icons/check.svg" alt="" aria-hidden="true"></button>
                    </div>

                    <div class="setting-row">
                        <div>
                            <div class="setting-labels">Logout?</div>
                        </div>
                        <button type="button" id="logout-btn" class="setting-action-btn neutral"><span class="ui-btn-label">Logout</span><img class="app-icon" src="/client/shared/assets/Icons/logout.svg" alt="" aria-hidden="true"></button>
                    </div>

                    <div class="setting-row">
                        <div>
                            <div class="setting-labels">Delete account?</div>
                        </div>
                        <button type="button" id="delete-account-btn" class="setting-action-btn danger"><span class="ui-btn-label">Delete</span><img class="app-icon" src="/client/shared/assets/Icons/delete.svg" alt="" aria-hidden="true"></button>
                    </div>
                </div>

                <div class="settings-panel hidden" data-panel="customise">
                    <div class="setting-row">
                        <div>
                            <div class="setting-labels">Theme</div>
                        </div>

                        <button type="button" id="theme-switch" aria-label="Switch to dark mode" aria-pressed="false">
                            <img src="/client/shared/assets/Icons/dark-mode.svg" alt="" aria-hidden="true">
                            <img src="/client/shared/assets/Icons/light-mode.svg" alt="" aria-hidden="true">
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="system-settings">
    <button id="system-settings-btn" aria-label="System settings"><img class="app-icon" src="/client/shared/assets/Icons/system-settings.svg" alt="" aria-hidden="true"></button>
</div>
